# CyberGuard — Environment Variables
# Copy this file to .env and fill in your values

# ── AI Provider (set ONE of the two below) ──────────────────────────────────

# OPTION 1 — Groq (FREE, no credit card needed)
# Sign up at console.groq.com → API Keys → Create API Key
# Model used: llama-3.3-70b-versatile  |  Free tier: 14,400 req/day
GROQ_API_KEY=gsk_...

# OPTION 2 — OpenAI (paid, ~$0.002 per conversation)
# Get key at platform.openai.com/api-keys
# Model used: gpt-4o-mini
OPENAI_API_KEY=sk-...

# If both are set, GROQ_API_KEY takes priority.

# Optional: Set a fixed secret key for production (generates random if not set)
SECRET_KEY=change-me-in-production

# Optional: 'development' or 'production'
FLASK_ENV=development

# Optional: Set to 'false' to disable debug mode
FLASK_DEBUG=true

# Optional: Path to SQLite database
DATABASE_PATH=cyberguard.db
